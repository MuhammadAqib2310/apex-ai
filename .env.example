PORT=5000

# Anthropic API — get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MODEL=claude-sonnet-4-6

# Twelve Data — free API key at https://twelvedata.com/pricing (free tier: 800 requests/day)
# Powers live Forex, Crypto, Stock & Index quotes
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# JWT signing secret — change this to a long random string in production
JWT_SECRET=change-this-to-a-long-random-secret-string
